# ─── App ──────────────────────────────────────────────────────────────────────
APP_PORT=3004
APP_ENV=development

# ─── Database ─────────────────────────────────────────────────────────────────
# Same Neon Postgres — never run prisma migrate in this service
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# ─── JWT (shared with api/auth/ — validates user tokens issued there) ──────────
# MUST be identical to JWT_SECRET in api/auth/
JWT_SECRET=same_secret_as_auth_service_here

# ─── Institution Encryption ───────────────────────────────────────────────────
# Master secret for per-institution private key derivation
# Unique to api/institution/ — never share with any other service
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
INSTITUTION_ENCRYPTION_SECRET=generate_a_unique_64_char_secret_for_institution_service

# ─── AWS S3 ───────────────────────────────────────────────────────────────────
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_S3_BUCKET_NAME=your_s3_bucket_name

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Optional additional allowed origins, comma-separated.
# Add the admin app and the documents app so they can call the institution API.
FRONTEND_URLS=http://localhost:4001,http://localhost:4002