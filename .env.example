# institution environment - managed by secret ownership cleanup.
# Keep this file key-compatible with the sibling .env files in this project.

# App
APP_PORT=3004
APP_ENV=development

# Runtime database
# Runtime access only. api/database owns migrations and seeds.
# Database role: gracon_institution_app
# Generate this role password with: node -e "console.log(require('crypto').randomBytes(24).toString('base64url'))"
# Deployment secret source: INSTITUTION_DATABASE_URL
DATABASE_URL=postgresql://gracon_institution_app:password@host/dbname?sslmode=require

# Shared user JWT
# Must match api/auth JWT_SECRET.
# Deployment secret source: PLATFORM_USER_JWT_SECRET
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=

# Institution private-key encryption
# Deployment secret source: INSTITUTION_PRIVATE_KEY_ENCRYPTION_SECRET
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
INSTITUTION_ENCRYPTION_SECRET=

# AWS S3
# Deployment secret source: PLATFORM_AWS_REGION
AWS_REGION=us-east-1
# Deployment secret source: PLATFORM_AWS_ACCESS_KEY_ID
AWS_ACCESS_KEY_ID=
# Deployment secret source: PLATFORM_AWS_SECRET_ACCESS_KEY
AWS_SECRET_ACCESS_KEY=
# Deployment secret source: PLATFORM_AWS_S3_BUCKET_NAME
AWS_S3_BUCKET_NAME=

# Frontend and CORS
FRONTEND_URL=http://localhost:4000
FRONTEND_URLS=http://localhost:4001,http://localhost:4002
